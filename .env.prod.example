# Copy this to .env.prod.local on the server (inside DEPLOY_PATH) and fill in real values.
# This file is read by the php container via env_file: in compose.prod.yaml.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=generate-with-openssl-rand-hex-32

# Plesk MariaDB — host.docker.internal resolves to the Plesk host from inside the container.
# Replace user/password/db. serverVersion must match the running MariaDB so Doctrine picks the right platform.
DATABASE_URL="mysql://treasury_user:CHANGE_ME@host.docker.internal:3306/treasury?serverVersion=10.6.22-MariaDB&charset=utf8mb4"

# Generation of absolute URLs (used by mailer, scheduler, console commands)
DEFAULT_URI=https://treasury.srv1.netlabs.dev

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null
